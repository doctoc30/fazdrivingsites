            <div class="accordion-content"><p style="padding: 20px;">Absolutely! We specialize in intensive "Fast Pass" courses. Contact us for current availability.</p></div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <div class="footer-grid">
            <div>
                <div class="footer-logo"><b>YELLOW SCHOOL</b></div>
                <p>Providing quality driving instruction in East London since 2004. Safety-first training for a lifetime of confident driving.</p>
            </div>
            <div class="footer-links">
                <h4>QUICK LINKS</h4>
                <ul>
                    <li><a href="#about">About Us</a></li>
                    <li><a href="#pricing">Pricing</a></li>
                    <li><a href="#areas">Locations</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h4>COURSES</h4>
                <ul>
                    <li><a href="#">Manual</a></li>
                    <li><a href="#">Automatic</a></li>
                    <li><a href="#">Intensive</a></li>
