<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yellow School of Motoring | East London's Top Driving School</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        :root {
            --primary: #FFD700; /* Signature Yellow */
            --dark: #111111;    /* Deep Black */
            --accent-dark: #e6c200;
            --light: #f9f9f9;
            --white: #ffffff;
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Poppins', sans-serif; background: var(--white); color: var(--dark); overflow-x: hidden; line-height: 1.6; }

        /* TYPOGRAPHY */
        h1, h2, h3, .brand { font-family: 'Montserrat', sans-serif; font-weight: 800; text-transform: uppercase; letter-spacing: -0.5px; }
        p { color: #333; }

        /* BUTTONS */
        .btn { display: inline-block; padding: 15px 35px; border-radius: 50px; font-weight: 700; text-decoration: none; transition: var(--transition); cursor: pointer; border: none; text-align: center; text-transform: uppercase; font-size: 0.9rem; }
        .btn-primary { background: var(--primary); color: var(--dark); box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3); }
        .btn-primary:hover { background: var(--dark); color: var(--primary); transform: translateY(-3px); }
        .btn-dark { background: var(--dark); color: var(--primary); }
        .btn-outline { border: 2px solid var(--dark); color: var(--dark); }

        /* STICKY NAV */
        nav { position: fixed; top: 0; width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 15px 8%; background: var(--white); z-index: 1000; transition: var(--transition); border-bottom: 3px solid var(--primary); }
        nav.scrolled { padding: 10px 8%; box-shadow: 0 5px 20px rgba(0,0,0,0.1); }
        .nav-links { display: flex; list-style: none; gap: 25px; align-items: center; }
        .nav-links a { color: var(--dark); text-decoration: none; font-size: 0.85rem; font-weight: 700; }
        .nav-links a:hover { color: var(--accent-dark); }
        
        .logo-container { display: flex; align-items: center; gap: 10px; text-decoration: none; }

        /* HAMBURGER */
        .hamburger { display: none; cursor: pointer; flex-direction: column; gap: 5px; z-index: 1001; }
        .hamburger span { width: 28px; height: 3px; background: var(--dark); transition: 0.3s; }

        /* TOP OFFER SLIDER */
        .top-ticker { background: var(--dark); height: 40px; overflow: hidden; display: flex; align-items: center; margin-top: 85px; }
        .ticker-wrap { display: flex; white-space: nowrap; animation: ticker 30s linear infinite; }
        .ticker-item { padding: 0 30px; color: var(--primary); font-weight: 700; font-size: 0.75rem; text-transform: uppercase; }
        @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

        /* HERO SECTION */
        .hero { height: 85vh; background: linear-gradient(rgba(255, 215, 0, 0.1), rgba(255, 215, 0, 0.1)), url('https://images.unsplash.com/photo-1449960232335-d8f914a50d11?q=80&w=2000&auto=format&fit=crop'); background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center; text-align: center; padding: 0 5%; border-bottom: 10px solid var(--primary); }
        .hero-content { background: rgba(255, 255, 255, 0.95); padding: 50px; border-radius: 20px; border: 4px solid var(--dark); box-shadow: 20px 20px 0px var(--primary); max-width: 900px; }
        .hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); color: var(--dark); margin-bottom: 15px; line-height: 1.1; }
        .hero p { color: #222; font-size: 1.1rem; font-weight: 500; margin-bottom: 30px; }
        .hero-btns { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }

        /* STATS */
        .stats { background: var(--dark); padding: 50px 10%; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; text-align: center; border-bottom: 5px solid var(--primary); }
        .stat-card { color: var(--white); }
        .stat-card .num { font-size: 2.8rem; font-weight: 800; color: var(--primary); display: block; }
        .stat-card p { color: var(--white); text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; }

        /* ABOUT SECTION */
        .about-section { padding: 100px 10%; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
        .about-image { position: relative; }
        .about-image img { width: 100%; border-radius: 15px; border: 3px solid var(--dark); }
        .about-image::after { content: ''; position: absolute; top: 20px; left: -20px; width: 100%; height: 100%; border: 3px solid var(--primary); border-radius: 15px; z-index: -1; }

        /* SERVICE GRID */
        .service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; padding: 50px 10%; }
        .service-card { background: var(--light); padding: 40px; border-radius: 0px; text-align: left; transition: var(--transition); border-left: 8px solid var(--primary); position: relative; }
        .service-card:hover { transform: translateY(-5px); background: var(--white); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        .service-card i { font-size: 2rem; color: var(--dark); margin-bottom: 20px; background: var(--primary); width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 50%; }

        /* REVIEWS */
        .reviews-section { padding: 80px 10%; background: var(--dark); color: var(--white); text-align: center; }
        .review-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 25px; margin-top: 50px; }
        .review-card { background: #222; padding: 30px; border-radius: 10px; border-top: 4px solid var(--primary); text-align: left; }
        .stars { color: var(--primary); margin-bottom: 10px; }

        /* PRICING */
        .pricing { padding: 100px 10%; background: var(--light); text-align: center; }
        .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-top: 50px; }
        .price-card { background: var(--white); padding: 40px; border: 3px solid var(--dark); position: relative; transition: var(--transition); }
        .price-card.featured { transform: scale(1.05); z-index: 2; box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
        .price-card.featured::before { content: 'BEST VALUE'; position: absolute; top: -15px; left: 50%; transform: translateX(-50%); background: var(--dark); color: var(--primary); padding: 5px 20px; font-weight: 800; font-size: 0.7rem; }
        .price-card h3 { font-size: 1.5rem; margin-bottom: 10px; }
        .price-card .cost { font-size: 3.5rem; font-weight: 800; margin: 20px 0; border-bottom: 2px solid var(--primary); display: inline-block; }
        .price-list { list-style: none; margin-bottom: 30px; text-align: left; }
        .price-list li { margin-bottom: 10px; font-weight: 500; display: flex; align-items: center; gap: 10px; }
        .price-list i { color: #27ae60; }

        /* MAP AREA */
        .areas { padding: 80px 10%; display: grid; grid-template-columns: 1.2fr 1fr; gap: 50px; align-items: center; }
        .area-list { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 20px; }
        .area-item { background: var(--primary); padding: 10px; font-weight: 700; font-size: 0.8rem; text-align: center; clip-path: polygon(5% 0%, 100% 0%, 95% 100%, 0% 100%); }

        /* FAQ */
        .faq { padding: 100px 15%; background: var(--white); }
        .accordion-item { border: 2px solid var(--dark); margin-bottom: 15px; }
        .accordion-header { padding: 20px; cursor: pointer; display: flex; justify-content: space-between; font-weight: 700; background: var(--primary); color: var(--dark); }
        .accordion-content { max-height: 0; overflow: hidden; transition: 0.3s ease-out; padding: 0 20px; }

        /* FOOTER */
        footer { background: var(--dark); padding: 80px 10% 120px; color: var(--white); }
        .footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1.5fr; gap: 40px; }
        .footer-logo { color: var(--primary); font-size: 1.8rem; margin-bottom: 20px; }
        .footer-links h4 { color: var(--primary); margin-bottom: 25px; font-size: 0.9rem; text-transform: uppercase; }
        .footer-links ul { list-style: none; }
        .footer-links li { margin-bottom: 12px; }
        .footer-links a { color: #bbb; text-decoration: none; font-size: 0.9rem; transition: 0.3s; }
        .footer-links a:hover { color: var(--primary); padding-left: 5px; }

        /* DOCK */
        .bottom-dock { position: fixed; bottom: 0; width: 100%; background: var(--white); display: flex; justify-content: space-around; padding: 15px; z-index: 999; border-top: 4px solid var(--primary); box-shadow: 0 -5px 20px rgba(0,0,0,0.1); }
        .dock-item { color: var(--dark); text-decoration: none; display: flex; flex-direction: column; align-items: center; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; gap: 5px; }
        .dock-item i { font-size: 1.4rem; color: var(--dark); }
        .dock-item.whatsapp i { color: #25D366; }

        /* POPUP */
        .popup-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 10000; display: none; justify-content: center; align-items: center; }
        .popup-box { background: var(--white); padding: 40px; border-radius: 0; text-align: center; max-width: 450px; position: relative; border: 10px solid var(--primary); }
        .close-popup { position: absolute; top: 10px; right: 15px; font-size: 1.5rem; cursor: pointer; color: var(--dark); font-weight: 800; }

        @media (max-width: 992px) {
            .about-section, .areas, .footer-grid, .hero-content { grid-template-columns: 1fr; text-align: center; }
            .hero-content { padding: 30px; }
            .hamburger { display: flex; }
            .nav-links { position: fixed; top: 0; right: -100%; height: 100vh; width: 80%; background: var(--white); flex-direction: column; justify-content: center; transition: 0.5s; box-shadow: -10px 0 30px rgba(0,0,0,0.1); }
            .nav-links.active { right: 0; }
            .area-list { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- EXIT POPUP -->
    <div class="popup-overlay" id="exitPopup">
        <div class="popup-box">
            <span class="close-popup" id="closeP">CLOSE</span>
            <h2 style="margin-bottom: 15px;">WAIT! NEW STUDENT?</h2>
            <div style="background: var(--primary); color: var(--dark); padding: 15px; font-weight: 800; font-size: 1.2rem; margin-bottom: 20px;">SAVE £10 ON INTENSIVE COURSES</div>
            <p style="margin-bottom: 25px;">Start your journey in East London with our safety-first approach. Only for students & NHS staff!</p>
            <a href="https://wa.me/02085398888" class="btn btn-dark" style="width: 100%;">CLAIM ON WHATSAPP</a>
        </div>
    </div>

    <!-- NAVIGATION -->
    <nav id="mainNav">
        <a href="#" class="logo-container">
            <svg width="150" height="50" viewBox="0 0 150 50">
                <!-- Road Path -->
                <rect x="0" y="35" width="60" height="15" fill="#111" />
                <rect x="5" y="42" width="10" height="2" fill="#fff" />
                <rect x="25" y="42" width="10" height="2" fill="#fff" />
                <rect x="45" y="42" width="10" height="2" fill="#fff" />
                <!-- YSM Text -->
                <text x="5" y="30" font-family="Montserrat" font-weight="800" font-size="28" fill="#111">YSM</text>
