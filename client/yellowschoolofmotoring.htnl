                <rect x="65" y="5" width="25" height="25" fill="#fff" stroke="#111" stroke-width="2"/>
                <path d="M72 10 V25 H83" fill="none" stroke="#e74c3c" stroke-width="4"/>
                <!-- Label -->
                <text x="65" y="45" font-family="Montserrat" font-weight="600" font-size="8" fill="#111">YELLOW SCHOOL</text>
            </svg>
        </a>
        <div class="hamburger" id="hamburger">
            <span></span><span></span><span></span>
        </div>
        <ul class="nav-links" id="navLinks">
            <li><a href="#about">OUR SCHOOL</a></li>
            <li><a href="#services">SERVICES</a></li>
            <li><a href="#pricing">PACKAGES</a></li>
            <li><a href="#areas">LOCATIONS</a></li>
            <li><a href="tel:02085398888" class="btn btn-primary" style="padding: 10px 20px;">CALL US</a></li>
        </ul>
    </nav>

    <div class="top-ticker">
        <div class="ticker-wrap">
            <div class="ticker-item">★ ESTABLISHED 2004 IN LEYTON</div>
            <div class="ticker-item">★ 20+ YEARS EXPERIENCE</div>
            <div class="ticker-item">★ DVSA APPROVED INSTRUCTORS</div>
            <div class="ticker-item">★ MANUAL & AUTOMATIC LESSONS</div>
            <div class="ticker-item">★ EXPERTS IN EAST LONDON TEST ROUTES</div>
            <div class="ticker-item">★ NERVOUS DRIVER SPECIALISTS</div>
        </div>
    </div>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-content" data-aos="zoom-in">
            <h4 style="color: #666; letter-spacing: 3px; font-weight: 700; margin-bottom: 10px;">YELLOW SCHOOL OF MOTORING</h4>
            <h1>EAST LONDON'S LOCAL DRIVING SCHOOL</h1>
            <p>Providing expert driver training for over two decades. Whether you're a teenager getting behind the wheel for the first time or an experienced driver looking for a refresher, we're here to help.</p>
            <div class="hero-btns">
                <a href="https://wa.me/02085398888" class="btn btn-primary">BOOK VIA WHATSAPP</a>
                <a href="#pricing" class="btn btn-outline">VIEW PRICE LIST</a>
            </div>
        </div>
    </section>

    <!-- STATS -->
    <div class="stats">
        <div class="stat-card" data-aos="fade-up">
            <span class="num">2004</span>
            <p>ESTABLISHED</p>
        </div>
        <div class="stat-card" data-aos="fade-up" data-aos-delay="100">
            <span class="num">20+</span>
            <p>YEARS EXP</p>
        </div>
        <div class="stat-card" data-aos="fade-up" data-aos-delay="200">
            <span class="num">100%</span>
            <p>DVSA QUALIFIED</p>
        </div>
        <div class="stat-card" data-aos="fade-up" data-aos-delay="300">
            <span class="num">1000s</span>
            <p>PASSED STUDENTS</p>
        </div>
    </div>

    <!-- ABOUT -->
    <section class="about-section" id="about">
        <div class="about-image" data-aos="fade-right">
            <img src="https://images.unsplash.com/photo-1521791136064-7986c2959d99?q=80&w=800&auto=format&fit=crop" alt="YSM Instruction">
        </div>
        <div data-aos="fade-left">
            <h2 style="font-size: 2.2rem; margin-bottom: 20px;">SAFETY-FIRST APPROACH</h2>
            <p style="margin-bottom: 20px; font-weight: 600;">Based in Leyton, E10, we have helped hundreds of students across East London pass their practical tests and beyond.</p>
            <p style="margin-bottom: 25px;">When your child is ready to drive, you need an instructor who isn't just teaching them to pass, but teaching them to be a safe, confident driver for life. We know the local test routes inside out—from Wanstead to Chingford.</p>
            <ul style="list-style: none; margin-bottom: 30px;">
                <li style="margin-bottom: 10px;"><i class="fas fa-check-circle" style="color: var(--primary);"></i> Expert Male & Female Instructors</li>
                <li style="margin-bottom: 10px;"><i class="fas fa-check-circle" style="color: var(--primary);"></i> Modern Dual-Controlled Vehicles</li>
                <li style="margin-bottom: 10px;"><i class="fas fa-check-circle" style="color: var(--primary);"></i> High Success Rate in East London</li>
            </ul>
            <a href="tel:02085398888" class="btn btn-dark">TALK TO AN EXPERT</a>
        </div>
    </section>

    <!-- SERVICES -->
    <section id="services" style="background: var(--white); padding: 80px 0;">
        <h2 style="text-align: center; margin-bottom: 50px;">OUR TRAINING PROGRAMS</h2>
        <div class="service-grid">
            <div class="service-card" data-aos="fade-up">
                <i class="fas fa-car"></i>
                <h3>MANUAL & AUTO</h3>
                <p>Tailored lessons in your choice of transmission. Perfect for beginners or nervous learners.</p>
            </div>
            <div class="service-card" data-aos="fade-up" data-aos-delay="100">
                <i class="fas fa-bolt"></i>
                <h3>INTENSIVE COURSES</h3>
